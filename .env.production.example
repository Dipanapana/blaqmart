# ===========================================
# Blaqmart Stationery - Production Environment
# ===========================================
# Copy this file to .env.production and fill in the values
# NEVER commit .env.production to version control

# Database (PostgreSQL for production)
# Get a free PostgreSQL database from: https://neon.tech, https://supabase.com, or https://railway.app
DATABASE_URL="postgresql://user:password@host:5432/blaqmart?sslmode=require"

# Auth
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-a-secure-32-character-secret"

# PayFast Payment Gateway (South Africa)
# Sign up at: https://www.payfast.co.za
# Use sandbox credentials for testing, production credentials for live
PAYFAST_MERCHANT_ID="your-merchant-id"
PAYFAST_MERCHANT_KEY="your-merchant-key"
PAYFAST_PASSPHRASE="your-passphrase"

# Yoco Payment Gateway (Alternative/Backup)
# Sign up at: https://www.yoco.com/za/online-checkout/
YOCO_SECRET_KEY="sk_live_your-key"
YOCO_PUBLIC_KEY="pk_live_your-key"
YOCO_WEBHOOK_SECRET="your-webhook-secret"

# Twilio (SMS Notifications)
# Sign up at: https://www.twilio.com
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+27xxxxxxxxx"

# Resend (Email Notifications)
# Sign up at: https://resend.com
RESEND_API_KEY="re_your-api-key"
EMAIL_FROM="Blaqmart <orders@blaqmart.co.za>"

# Supabase Storage (Image uploads)
# Sign up at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# App Configuration
NEXT_PUBLIC_URL="https://your-domain.com"
ADMIN_EMAIL="admin@blaqmart.co.za"

# Performance
NODE_OPTIONS="--max-old-space-size=4096"

# ===========================================
# Deployment Checklist:
# ===========================================
# 1. Set up PostgreSQL database
# 2. Run: npx prisma migrate deploy
# 3. Run: npx prisma db seed
# 4. Configure PayFast webhook: POST /api/payments/webhook
# 5. Configure Yoco webhook if using
# 6. Test checkout flow in sandbox mode first
# 7. Verify email/SMS notifications work
# ===========================================
